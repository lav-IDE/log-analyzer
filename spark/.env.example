# Spark and Hadoop Configuration
# Copy this file to .env and update values for your environment

# Local IP address for Spark
SPARK_LOCAL_IP=127.0.0.1

# Path to Hadoop configuration directory
HADOOP_CONF_DIR=/opt/hadoop/etc/hadoop

# HDFS Namenode address
HDFS_NAMENODE=hdfs://master:9000

# HDFS path to input logs
LOG_INPUT_PATH=/raw_logs/generated_logs

# HDFS path to Spark JARs archive
SPARK_JARS_PATH=
